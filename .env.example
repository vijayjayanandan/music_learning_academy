DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# Stripe (use test keys for development)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid (email delivery)
SENDGRID_API_KEY=SG.xxx
DEFAULT_FROM_EMAIL=Music Academy <noreply@musicacademy.app>

# Cloudflare R2 / AWS S3 (file storage — production only)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Database (production — dev uses SQLite)
DB_NAME=music_academy
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis (Channels layer + Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Jitsi
JITSI_DOMAIN=jitsi.member.fsf.org

# Dev overrides
USE_CONSOLE_EMAIL=1
