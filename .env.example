# =============================================================================
# Music Learning Academy — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Lines starting with # are comments. Remove # to enable a setting.

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1
# DEBUG=True  # Only for dev; prod.py forces DEBUG=False

# Admin URL (obfuscated for security)
# ADMIN_URL_PATH=manage-internal/

# -----------------------------------------------------------------------------
# Database (production — dev uses SQLite automatically)
# -----------------------------------------------------------------------------
DB_NAME=music_academy
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis (Channels layer + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Cron (external scheduler — replaces Celery Beat)
# -----------------------------------------------------------------------------
# Generate a random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Configure cron-job.org to POST to /cron/ with Authorization: Bearer <key>
CRON_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (use test keys for development)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxx
DEFAULT_FROM_EMAIL=Music Academy <noreply@musicacademy.app>
# USE_CONSOLE_EMAIL=1  # Dev: print emails to console instead of sending

# -----------------------------------------------------------------------------
# File Storage (Cloudflare R2 / AWS S3 — production only)
# -----------------------------------------------------------------------------
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# Jitsi Meet (live video sessions)
# -----------------------------------------------------------------------------
JITSI_DOMAIN=jitsi.member.fsf.org

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Session & Security (production)
# -----------------------------------------------------------------------------
# SESSION_COOKIE_AGE=86400
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# -----------------------------------------------------------------------------
# Social Login (Google & Facebook OAuth)
# -----------------------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# SITE_DOMAIN=localhost:8001

# -----------------------------------------------------------------------------
# Domain Setup (Cloudflare DNS + Render Hosting)
# -----------------------------------------------------------------------------
# CLOUDFLARE_API_TOKEN=        # Create at: Cloudflare > My Profile > API Tokens (Zone.DNS Edit)
# CLOUDFLARE_ZONE_ID=          # Found on: Cloudflare > onemusicapp.com > Overview (right sidebar)
# RENDER_API_KEY=              # Found at: Render > Account Settings > API Keys
# RENDER_SERVICE_ID=           # Found at: Render > Service > Settings (or via API)

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
